# Supabase client runtime configuration.
# Safe to expose in browser/mobile clients.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Driver Flutter web build/runtime values.
# Pass these with --dart-define, for example:
# flutter build web --dart-define=SUPABASE_URL=... --dart-define=SUPABASE_ANON_KEY=... --dart-define=SUPABASE_OAUTH_REDIRECT_URL=...
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_OAUTH_REDIRECT_URL=

# Optional public Google OAuth client ID if a client SDK flow needs it.
# Google OAuth secrets stay configured in Supabase, not app runtime env.
VITE_GOOGLE_CLIENT_ID=
FLUTTER_GOOGLE_CLIENT_ID=

# Local Supabase CLI/project metadata. Do not commit real secrets.
SUPABASE_PROJECT_REF=
