{
  "name": "flovi-ai-build-challenge",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "test": "npm run test --workspaces --if-present",
    "coverage": "npm run coverage --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "dispatcher:dev": "npm run dev -w @flovi/dispatcher",
    "dispatcher:build": "npm run build -w @flovi/dispatcher",
    "driver:test": "docker run --rm -v \"$PWD/apps/driver:/workspace\" -w /workspace ghcr.io/cirruslabs/flutter:stable sh -lc 'flutter pub get && flutter test'",
    "driver:build": "docker run --rm -v \"$PWD/apps/driver:/workspace\" -w /workspace ghcr.io/cirruslabs/flutter:stable sh -lc 'flutter pub get && flutter build web'",
    "seed:demo": "node scripts/seed-supabase-demo-data.mjs"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.3",
    "@vue/test-utils": "^2.4.6",
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^27.3.0",
    "typescript": "5.9.3",
    "vite": "^7.2.7",
    "vitest": "^4.1.10",
    "vue": "^3.5.26",
    "vue-tsc": "^3.1.8"
  }
}
